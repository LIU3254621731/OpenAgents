{
  "app": {
    "version": "0.1.0",
    "language": "zh-CN",
    "theme": "light"
  },
  "model": {
    "type": "openai",
    "default_model": "gpt-4o-mini",
    "api_base_url": "https://api.openai.com/v1",
    "api_key": "sk-your-api-key-here",
    "timeout": 30
  },
  "discussion": {
    "max_rounds": 10,
    "max_time_per_round": 60,
    "max_total_time": 300
  },
  "knowledge_base": {
    "enabled": true,
    "vector_store_path": "config/vector_store.json"
  },
  "mcp": {
    "enabled": true,
    "timeout": 10
  }
}
